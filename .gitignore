# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json
**/test/**
# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
/android/build/

# Native build artifacts (CMake/NDK, used by FFI packages)
**/.cxx/
**/CMakeFiles/
**/CMakeCache.txt
packages/*/build/
packages/*/android/build/

# Local build logs
build_log*.txt

# Developer-only diagnostic / test scripts
/tool/

# Native platform unit-test targets
**/RunnerTests/

# Stray test output artifacts
*_out.txt
bktr_out.txt
